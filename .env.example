# Copy to .env and adjust. All settings are prefixed with MOVORA_.
MOVORA_APP_NAME=Movora

# All generated data — the SQLite database, transcodes, subtitle/audio caches, thumbnails and
# the log — lives under this one directory (keeps things tidy and easy to back up or wipe).
MOVORA_DATA_DIR=var
# Optional: override just the database file (defaults to {MOVORA_DATA_DIR}/movora.db).
# MOVORA_DATABASE_PATH=

# REQUIRED in production: secret used to sign the login session cookie. Leaving the
# insecure default lets sessions be forged. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
MOVORA_SECRET_KEY=change-me

# Free TMDB v3 API key for film/series metadata (https://www.themoviedb.org/settings/api).
# Without it, anime (AniList) still works; film/series metadata is skipped.
# MOVORA_TMDB_API_KEY=

# Path to the media library to mount (read-only) in docker compose:
# MOVORA_MEDIA=/path/to/media

# Set to true when serving over HTTPS (reverse proxy / Cloudflare Tunnel / Tailscale Funnel).
# Tells the browser to send the session cookie only over encrypted connections.
MOVORA_COOKIE_SECURE=false

# Session lifetime in seconds. Default: 1 209 600 (14 days).
# MOVORA_SESSION_TTL_SECONDS=1209600

# Cross-origin allow-list for clients NOT served same-origin, e.g. the webOS TV app
# (it authenticates with a bearer token, not cookies). Comma-separated; "*" allows any.
# The web UI is same-origin and unaffected, and every /api route still requires auth.
# Restrict it if you know the client origins, e.g. MOVORA_CORS_ORIGINS=http://192.168.1.20
MOVORA_CORS_ORIGINS=*
